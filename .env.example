# Environment Configuration Example
# Copy this to .env and adjust values for local development

# App Settings
PROJECT_NAME="RideSharingApp"
ENVIRONMENT=development
DEBUG=true

# Database Settings
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ridesharing
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/ridesharing

# JWT Authentication
JWT_SECRET=super_secret_jwt_key_change_me_in_production_1234567890
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Redis Configuration (Cache, Message Broker & Websocket Sync)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# Celery Configuration
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# External Services (Mocked by default)
MAP_SERVICE_API_KEY=mock_google_maps_api_key_or_leaflet_token
PAYMENT_GATEWAY_API_KEY=mock_stripe_or_paypal_api_key

# CORS & Security
ALLOWED_HOSTS=["*"]
RATE_LIMIT_PER_MINUTE=100
